---

<section class="timeline-section" id="memories">
  <div class="timeline-header fade-in-up" data-animate>
    <h2 class="timeline-title">لحظاتنا سوا</h2>
    <div class="timeline-subtitle">من أول يوم لحد النهاردة</div>
    <div class="timeline-divider">
      <span class="divider-line"></span>
      <span class="divider-heart">♥</span>
      <span class="divider-line"></span>
    </div>
  </div>

  <div class="timeline-container">
    <!-- The golden vertical line -->
    <div class="timeline-line" aria-hidden="true"></div>

    <div class="timeline-cards">
      {videos.map((video, index) => (
        <VideoCard
          videoSrc={video.src}
          date={video.date}
          caption={video.caption}
          index={index}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .timeline-section {
    position: relative;
    padding: var(--space-xl) var(--space-md);
    z-index: 1;
  }

  /* Section header */
  .timeline-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .timeline-title {
    font-family: var(--font-calligraphy);
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-gold);
    margin-bottom: var(--space-xs);
  }

  .timeline-subtitle {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--color-text-muted);
    font-weight: 300;
  }

  .timeline-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .divider-line {
    display: block;
    width: 60px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-gold),
      transparent
    );
  }

  .divider-heart {
    color: var(--color-rose);
    font-size: 0.9rem;
    animation: float 3s infinite;
  }

  /* Timeline container */
  .timeline-container {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* The golden vertical line */
  .timeline-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 2px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      var(--color-gold) 5%,
      var(--color-gold) 95%,
      transparent 100%
    );
    transform: translateX(-50%);
    opacity: 0.4;
  }

  .timeline-cards {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Mobile: hide the timeline line */
  @media (max-width: 768px) {
    .timeline-line {
      display: none;
    }

    .timeline-section {
      padding: var(--space-lg) var(--space-sm);
    }
  }
</style>
