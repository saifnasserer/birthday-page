---
// Scroll prompt — gentle nudge to scroll down
---

<div class="scroll-prompt" id="scroll-prompt">
  <p class="scroll-text">The first Page of our video Journal .. </p>
  <div class="scroll-arrow">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </div>
  <span class="scroll-heart">💛</span>
</div>

<style>
  .scroll-prompt {
    text-align: center;
    padding: var(--space-md) 0 var(--space-lg);
    opacity: 0;
    animation: fadeIn 1s 2.8s var(--ease-smooth) forwards;
  }

  .scroll-text {
    font-family: var(--font-calligraphy);
    font-size: clamp(1.1rem, 4vw, 1.6rem);
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
    letter-spacing: 0.03em;
  }

  .scroll-arrow {
    color: var(--color-gold);
    animation: bounce 2.5s infinite;
    opacity: 0.6;
  }

  .scroll-arrow svg {
    width: 24px;
    height: 24px;
  }

  .scroll-heart {
    display: block;
    margin-top: var(--space-xs);
    font-size: 0.9rem;
    opacity: 0.3;
    animation: float 4s infinite;
  }

  @media (max-width: 768px) {
    .scroll-prompt {
      padding: var(--space-sm) 0 var(--space-md);
    }
  }
</style>
