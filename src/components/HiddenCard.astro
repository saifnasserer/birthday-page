---
// Hidden Card — The secret surprise at the end
// Reveals a heartfelt letter with a confetti explosion
---

<section class="hidden-section" id="hidden-section">
  <!-- Extra whitespace to make her think the page is over -->
  <div class="spacer"></div>

  <div class="hidden-card-container" data-animate>
    <!-- The sealed envelope -->
    <div class="envelope" id="secret-envelope" role="button" tabindex="0" aria-label="اضغطي هنا">
      <div class="envelope-front">
        <div class="envelope-seal">
          <span class="seal-heart">💌</span>
        </div>
        <p class="envelope-hint">بعشقك ..</p>
        <div class="envelope-shimmer"></div>
      </div>

      <!-- The revealed letter -->
      <div class="envelope-reveal" id="envelope-reveal">
        <div class="reveal-bg"></div>
        
        <div class="letter-paper">
          <div class="letter-content">
            <p>عيدميلادك السنة دي مميز اوي الحقيقه ، لية مميز ؟</p>
            <p>اولاً هيبقا سهل تفتكري اول يوم دخلت فيه بيتكم واول يوم كلت من ايديكي ، قعدت مع عيلتك وعرفوني كلهم وكانوا مبسوطين ، ايقنت انك بتاعتي خلاص وانا جيت اخدك زي م قولتلك دايماً</p>
            <p>اما تاني حاجة ف هو اخر عيدميلاد ليكي هبقا بحارب فيه عشان اشوفك ، اخر عيدميلاد هتقضية لواحدك ايامنا اللي جاية سوا ي روو كل ايامنا بأذن الله ، كل اللي فات ده حاجة واللي جاي حاجة تانية خالص ، عيدميلادك النهارده هو يوم فاضل ل حياتنا اللي فاتت وايامنا اللي جاية سوا ، اوعدك هخليكي دايماً مبسوطه واحاول دايماً اخليكي تضحكي ، دايماً اشوف ابتسامتك</p>
            <p>بيتنا هنبنية سوا زي م احنا عايزين بالظبط ، هيبقا عندنا لوزة وبكيزة واخر اليوم هتنامي ف حضني</p>
            <p>عيدميلادك ده هو الاخير اللي هتبقي فية بعيد عن حضني ، بحبك اوي بحبك اوي بجد</p>
            <br>
            <p>متأكد انك رزقي في الدنيا ، اصل مش طبيعي ، انتي مش طبيعيه خالص ازاي تبقي حلوة بالشكل ده !</p>
            <p>ازاي تبهريني دايماً بالشكل ده ؟ بحب كل حاجة فيكي كل حاجة شخصيتك احلامك حبك ليا ، ريأكشناتك وملامح وشك بحب تفاصيلك اوي بحب شكل عيونك ، بحب صوابع ايدك بحب امسك ايدك اوي ابوسها بحب كل حاجة فيكي ي روو ، انتي مخدرات بالنسبالي وانا ادمنتك ، ادمنت تفاصيلك ، انا عايز باقي حياتي معاكي ، معاكي وبس اوعدك دايماً هحاول اخليكي مبسوطه دايماً - بحبك</p>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</section>

<script>
  import confetti from 'canvas-confetti';

  document.addEventListener('DOMContentLoaded', () => {
    const envelope = document.getElementById('secret-envelope');
    const reveal = document.getElementById('envelope-reveal');
    let isRevealed = false;

    function triggerConfetti() {
      const colors = ['#d4a853', '#e8c97a', '#c4727a', '#e8a5ab', '#f5ece3'];

      // Main burst
      confetti({
        particleCount: 100,
        spread: 80,
        origin: { y: 0.6, x: 0.5 },
        colors: colors,
        ticks: 200,
        gravity: 0.8,
        decay: 0.94,
      });

      // Side bursts
      setTimeout(() => {
        confetti({
          particleCount: 60,
          angle: 60,
          spread: 55,
          origin: { x: 0.1, y: 0.6 },
          colors: colors,
          gravity: 0.8,
        });
      }, 200);

      setTimeout(() => {
        confetti({
          particleCount: 60,
          angle: 120,
          spread: 55,
          origin: { x: 0.9, y: 0.6 },
          colors: colors,
          gravity: 0.8,
        });
      }, 350);
      
      // Final romantic burst
      setTimeout(() => {
        confetti({
          particleCount: 40,
          spread: 120,
          origin: { y: 0.5, x: 0.5 },
          colors: ['#c4727a', '#e8a5ab'],
          shapes: ['circle'],
          scalar: 1.3,
          gravity: 0.6,
        });
      }, 550);
    }

    function revealSecret(e) {
      // Don't close or re-trigger if already revealed
      if (isRevealed) {
        // Only prevent default if they aren't trying to scroll
        return;
      }
      isRevealed = true;

      // Add classes for animations
      envelope?.classList.add('opened');
      reveal?.classList.add('visible');
      document.getElementById('hidden-section')?.classList.add('revealed');

      // Vibrate on mobile
      if ('vibrate' in navigator) {
        navigator.vibrate([50, 30, 50]);
      }

      triggerConfetti();

      // Trigger n8n Webhook (which will call Evolution API)
      const webhookUrl = 'https://n8n-auto.fixzzone.com/webhook/saif'; 
      
      fetch(webhookUrl, { method: 'POST' })
        .then(res => console.log('n8n Webhook triggered:', res.status))
        .catch(err => console.error('Failed to trigger n8n:', err));
    }

    // Envelope click
    envelope?.addEventListener('click', revealSecret);
    
    // Keyboard support
    envelope?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        revealSecret(e);
      }
    });
  });
</script>

<style>
  .hidden-section {
    position: relative;
    z-index: 1;
    background: var(--color-bg-deep);
    transition: background 1.5s var(--ease-smooth);
    min-height: 100vh;
  }

  .hidden-section.revealed {
    background: radial-gradient(
      ellipse at center,
      #2a1810 0%,
      #1a0f0a 60%,
      #0d0705 100%
    );
  }

  .spacer {
    height: 15vh;
  }

  .hidden-card-container {
    display: flex;
    justify-content: center;
    padding-bottom: var(--space-2xl);
    min-height: 60vh;
    align-items: center;
    /* Animation */
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s var(--ease-smooth), transform 0.8s var(--ease-smooth);
  }

  .hidden-card-container.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Envelope */
  .envelope {
    position: relative;
    width: 220px;
    height: 160px;
    cursor: pointer;
    transition: transform 0.3s var(--ease-smooth);
    outline: none;
    /* Better touch target */
    touch-action: manipulation;
    -webkit-user-select: none;
    user-select: none;
  }

  /* When opened, reset dimensions and position for the letter */
  .envelope.opened {
    width: 100%;
    max-width: 600px;
    height: auto;
    cursor: default;
    transform: none !important;
  }

  /* Desktop hover */
  @media (min-width: 769px) {
    .envelope:not(.opened):hover {
      transform: scale(1.08);
    }
  }

  /* Mobile active tap */
  .envelope:not(.opened):active {
    transform: scale(0.95);
  }

  .envelope:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 8px;
    border-radius: 8px;
  }

  .envelope-front {
    position: relative;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f5ece3 0%, #e8d5c4 100%);
    border-radius: 10px;
    box-shadow: var(--shadow-card), 0 0 25px rgba(212, 168, 83, 0.15);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    overflow: hidden;
    transition: opacity 0.6s var(--ease-smooth), transform 0.6s var(--ease-smooth);
    animation: envelopePulse 3s infinite;
  }

  @keyframes envelopePulse {
    0%, 100% {
      box-shadow: var(--shadow-card), 0 0 20px rgba(212, 168, 83, 0.1);
    }
    50% {
      box-shadow: var(--shadow-card), 0 0 40px rgba(212, 168, 83, 0.25);
    }
  }

  .envelope.opened .envelope-front {
    opacity: 0;
    transform: scale(0.5) translateY(100px);
    pointer-events: none;
    position: absolute;
  }

  .envelope-seal {
    font-size: 2.5rem;
    animation: float 3s infinite;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.15));
  }

  .envelope-hint {
    font-family: var(--font-calligraphy);
    font-size: 1.1rem;
    color: var(--color-text-caption);
    opacity: 0.8;
    animation: fadeIn 2s infinite alternate;
  }

  .envelope-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(212, 168, 83, 0.12) 50%,
      transparent 100%
    );
    background-size: 200% 100%;
    animation: shimmer 3s infinite linear;
    border-radius: 10px;
  }

  /* Reveal */
  .envelope-reveal {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden; /* Fixes overflow before opening */
    pointer-events: none;
    transition: opacity 0.8s 0.3s var(--ease-smooth), visibility 0s 1.1s;
  }

  .envelope.opened .envelope-reveal {
    position: relative;
    top: auto;
    left: auto;
    transform: none;
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 0.8s 0.3s var(--ease-smooth), visibility 0s 0s;
  }

  .reveal-bg {
    position: fixed;
    inset: 0;
    background: var(--gradient-reveal);
    animation: fadeIn 1s forwards;
    z-index: -1;
    opacity: 0;
    transition: opacity 1s var(--ease-smooth);
  }
  
  .envelope.opened .reveal-bg {
    opacity: 1;
  }

  /* The Letter Paper */
  .letter-paper {
    background: #fdfaf6;
    background-image: 
      linear-gradient(rgba(212, 168, 83, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212, 168, 83, 0.03) 1px, transparent 1px);
    background-size: 20px 20px;
    padding: var(--space-xl) var(--space-lg);
    border-radius: 8px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(212, 168, 83, 0.1);
    max-width: 90vw;
    width: 100%;
    transform: translateY(40px) scale(0.95);
    opacity: 0;
    transition: transform 1s 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.8s 0.4s var(--ease-smooth);
    position: relative;
  }

  .letter-paper::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 5px;
    background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
    opacity: 0.5;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
  }

  .envelope.opened .letter-paper {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .letter-content {
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: #3d2c23;
    line-height: 2.2;
    font-weight: 400;
    text-align: right;
  }

  .letter-content p {
    margin-bottom: 1.2rem;
  }
  
  .letter-content p:last-child {
    margin-bottom: 0;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .spacer {
      height: 10vh;
    }

    .envelope:not(.opened) {
      width: 180px;
      height: 140px;
    }

    .envelope-seal {
      font-size: 2.2rem;
    }

    .letter-paper {
      padding: var(--space-lg) var(--space-md);
      border-radius: 6px;
    }

    .letter-content {
      font-size: 1rem;
      line-height: 2;
    }
  }
</style>
